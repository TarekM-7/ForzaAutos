<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cars</title>
  </head>
  <body>
    <h1>ALL CARS</h1>
    <ul>
        <% for(let car of autos){ %>
           
            <li><a href="/cars/<%= car._id %>"><%= car.name %></a></li>

        <% } %>
    </ul>
    <a href="/cars/new">New Car</a>
  </body>
</html>
